# Production .env — copy to `.env` on the server and fill real values.
# NEVER commit the real .env (it is gitignored).

# --- Database (points at the `db` service inside docker compose) ---
POSTGRES_USER=karier
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=karier
DATABASE_URL=postgresql+asyncpg://karier:CHANGE_ME_STRONG_PASSWORD@db:5432/karier

# --- Auth / JWT ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS — every frontend origin (comma-separated, no trailing slash).
# Must include the custom domain (www + apex) AND the Vercel URLs of all 3 apps.
CORS_ORIGINS=https://www.raqamli-karyer.uz,https://raqamli-karyer.uz,https://web-main.vercel.app,https://web-department.vercel.app,https://web-quarry.vercel.app

# --- Quarry local-server ingest (/api/weigh) ---
WEIGH_API_KEYS=KARYER-01-SECRET,KARYER-02-SECRET
WEIGH_MAX_UPLOAD_MB=120
