# ───────────── Database (PostGIS) ─────────────
POSTGRES_USER=karier
POSTGRES_PASSWORD=karier
POSTGRES_DB=karier
POSTGRES_HOST=localhost
# 5440 to avoid clashing with a local host Postgres on 5432
POSTGRES_PORT=5440

# Async SQLAlchemy URL (backend reads this)
DATABASE_URL=postgresql+asyncpg://karier:karier@localhost:5440/karier

# ───────────── Backend ─────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Comma-separated allowed origins for the 3 frontends
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ───────────── Frontend (Vite) ─────────────
# Each app proxies /api -> this in dev (see vite.config.ts)
VITE_API_BASE=/api/v1
